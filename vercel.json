{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/debug-server",
      "destination": "/api/debug-server"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!assets|favicon.ico|icon.png).*)",
      "destination": "/index.html"
    }
  ]
}
